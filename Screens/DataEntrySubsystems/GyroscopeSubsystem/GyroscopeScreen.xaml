<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MOBWEB_TEST.Screens.DataEntrySubsystems.GyroscopeScreen"
             Title="Gyroscope Subsystem">
    <VerticalStackLayout Spacing="10" Padding="10,0" VerticalOptions="Center">
        <Label x:Name="CurrentAngleLabel"
            Text="Not started"
            HorizontalOptions="Center"
            FontSize="Medium"/>
        <Label x:Name="BaseAngleLabel"
            Text="Base: ---"
            HorizontalOptions="Center"/>
        <Label x:Name="LiveCrownBaseLabel"
            Text="Live Crown Base: ---"
            HorizontalOptions="Center"/>
        <Label x:Name="TopAngleLabel"
            Text="Top: ---"
            HorizontalOptions="Center"/>
        <Label x:Name="DifferenceLabel"
            Text=""
            HorizontalOptions="Center"
            FontAttributes="Bold"/>
        <Label x:Name="HeightResultLabel"
            Text="Height: -- ft"
            HorizontalOptions="Center"
            FontSize="Medium"
            FontAttributes="Bold"/>
        <Label x:Name="LiveCrownRatioLabel"
            Text="Live Crown Ratio : --- %"
            HorizontalOptions="Center"
            FontAttributes="Bold"/>
        <Label x:Name="BaseOfLiveCrownLabel"
            Text="Base Of Live Crown: --- ft"
            HorizontalOptions="Center"
            FontAttributes="Bold"/>
        <Button
            x:Name="TakeMeasurement"
            Text="Measure Gyroscope Angle"
            SemanticProperties.Hint="Keeps You Logged In"
            Clicked="OnGyroMeasureClicked"
            HorizontalOptions="Fill" />
        <Button Text="Zero Gyroscope"
            Clicked="OnZeroClicked"
            HorizontalOptions="Center"/>
        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button Text="Capture Base Angle"
                    Clicked="OnCaptureBaseClicked"/>
            <Button Text="Capture Top Angle"
                    Clicked="OnCaptureTopClicked"/>
        </HorizontalStackLayout>
        <Button Text="Capture Live Crown Base Angle"
            Clicked="OnCaptureLiveCrownBaseClicked"/>
        <Label Text="Distance (ft):" VerticalOptions="Center"/>
        <Entry x:Name="DistanceEntry"
            Placeholder="e.g., 100"
            Keyboard="Numeric"
            WidthRequest="100"/>
        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,20,0,0">
            <Button Text="Calculate Height"
                    Clicked="OnCalculateHeightClicked"/>
            <Button Text="Calculate Live Crown Ratio"
                    Clicked="OnCalculateLiveCrownRatioClicked"/>
        </HorizontalStackLayout>
        <Button Text="Enter Defect"
             Clicked="OnEnterDefectClicked"
             HorizontalOptions="Center"/>
        </VerticalStackLayout>
</ContentPage>