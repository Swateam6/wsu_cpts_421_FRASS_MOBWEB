<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MOBWEB_TEST.Screens.DataEntrySubsystems.PlotEntry"
             Title="Plot Initialization"
             BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource MidnightBlue}}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <Label Text="New Plot Waypoint" 
                   FontSize="24" 
                   FontFamily="OpenSansRegular"
                   TextColor="{StaticResource Primary}"
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,10"/>

            <Label Text="Plot Number:" 
                   FontFamily="OpenSansRegular"
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource Secondary}}"
                   FontAttributes="Bold" />
            <Entry x:Name="PlotNumEntry" 
                   Placeholder="e.g., 1" 
                   Keyboard="Numeric"
                   FontFamily="OpenSansRegular"
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"
                   ClearButtonVisibility="WhileEditing" />

            <Label Text="Slope (%):" 
                   FontFamily="OpenSansRegular"
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource Secondary}}"
                   FontAttributes="Bold" />
            <Entry x:Name="SlopeEntry" 
                   Placeholder="0.0" 
                   Keyboard="Numeric"
                   FontFamily="OpenSansRegular"
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"
                   ClearButtonVisibility="WhileEditing" />

            <Label Text="Aspect (Degrees 0-360):" 
                   FontFamily="OpenSansRegular"
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource Secondary}}"
                   FontAttributes="Bold" />
            <Entry x:Name="AspectEntry" 
                   Placeholder="e.g., 180" 
                   Keyboard="Numeric"
                   FontFamily="OpenSansRegular"
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}"
                   ClearButtonVisibility="WhileEditing" />

            <Button Text="Log First Tree" 
                    Clicked="OnLogFirstTreeClicked" 
                    Margin="0,20,0,0"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontFamily="OpenSansRegular"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>