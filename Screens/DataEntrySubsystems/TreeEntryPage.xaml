<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MOBWEB_TEST.Screens.DataEntrySubsystems.TreeEntryPage"
             Title="Tree Measurement"
             BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource MidnightBlue}}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Label Text="FRASS - Log Tree" 
                   FontSize="24" 
                   FontFamily="OpenSansRegular" 
                   TextColor="{StaticResource Primary}" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,10"/>

            <Label Text="Tree Species (e.g., DF, PP):" 
                   FontFamily="OpenSansRegular" 
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource Secondary}}" 
                   FontAttributes="Bold" />
            <Entry x:Name="SpeciesEntry" 
                   Placeholder="Enter Species" 
                   FontFamily="OpenSansRegular" 
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" 
                   ClearButtonVisibility="WhileEditing" />

            <Label Text="DBH (Inches):" 
                   FontFamily="OpenSansRegular" 
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource Secondary}}" 
                   FontAttributes="Bold" />
            <Entry x:Name="DbhEntry" 
                   Placeholder="0.0" 
                   Keyboard="Numeric" 
                   FontFamily="OpenSansRegular" 
                   TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" 
                   ClearButtonVisibility="WhileEditing" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">

                <Button x:Name="NextTreeButton"
                        Grid.Column="0"
                        Text="Next Tree" 
                        Clicked="OnNextTreeClicked" 
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" 
                        FontFamily="OpenSansRegular" 
                        FontSize="16" 
                        FontAttributes="Bold" 
                        CornerRadius="8"/>

                <Button x:Name="NextPlotButton"
                        Grid.Column="1"
                        Text="Next Plot" 
                        Clicked="OnNextPlotClicked" 
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" 
                        FontFamily="OpenSansRegular" 
                        FontSize="16" 
                        FontAttributes="Bold" 
                        CornerRadius="8"/>

            </Grid>
            <Button x:Name="FinishStandButton"
                        Text="Finish Stand" 
                        Clicked="OnFinishStandClicked" 
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" 
                        FontFamily="OpenSansRegular" 
                        FontSize="16" 
                        FontAttributes="Bold" 
                        CornerRadius="8"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>